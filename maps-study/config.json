{
  "$schema": "https://raw.githubusercontent.com/revisit-studies/study/v2.3.2/src/parser/StudyConfigSchema.json",
  "studyMetadata": {
    "title": "How well can you read different map types?",
    "version": "pilot",
    "authors": ["WPI"],
    "date": "2023-04-28",
    "description": "Univariate and Bivariate comparison study",
    "organizations": ["WPI", "University of Colorado Boulder"]
  },
  "uiConfig": {
    "contactEmail": "contact@revisit.dev",
    "helpTextPath": "maps-study/assets/help.md",
    "logoPath": "revisitAssets/revisitLogoSquare.svg",
    "withProgressBar": true,
    "autoDownloadStudy": false,
    "withSidebar": false,
    "urlParticipantIdParam": "PROLIFIC_PID",
    "recordAudio": true,
    "recordScreen": true,
    "studyEndMsg": "**Thank you for completing the study. You may click this link and return to Prolific**: [https://app.prolific.com/submissions/complete?cc=C1I69EG9](https://app.prolific.com/submissions/complete?cc=C1I69EG9)"
  },
  "studyRules": {
    "display": {
      "minHeight": 500,
      "minWidth": 1280
    }
  },
  "importedLibraries": ["screen-recording", "color-blindness"],

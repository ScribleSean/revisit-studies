    "univariate-1": {
      "description": "",
      "instruction": "The maps show two percentages: \n\n 🩺 The percentage of people in a given county who are on Medicaid and <br/> 🗳️ The percentage of people who voted for Donald Trump in the 2024 US presidential elections. \n\n  <b>Task</b>: ✅ Select 5 counties with **low** Medicaid participation rates and **high** Trump 2024 Vote Share. \n\n <b>Note:</b> Click on the map to ✅ select or ❌ de-select a county. \n\n <mark>**Please answer the question out loud 🗣️, as well as verbalize any insights, questions or challenges you have while 🔎 exploring the map.**</mark>",
      "type": "react-component",
      "path": "maps-study/assets/Univariate.tsx",
      "parameters": {
        "dataPath": "maps-study/assets/medicaid-trump.csv",
        "columnA": "voter_rate",
        "columnB": "medicaid_rate",
        "columnAFormat": "percentage",
        "columnBFormat": "percentage",
        "columnAScale": "linear",
        "columnBScale": "linear",
        "draw": false,
        "countySelections": true,
        "taskid": "selectedCounties"
      },
      "response": [
        {
          "id": "selectedCounties",
          "prompt": "You selected the following counties: ",
          "location": "belowStimulus",
          "type": "reactive",
          "hidden": true
        },
        {
          "id": "thinkaloud",
          "prompt": "Have you verbalized your thoughts?",
          "location": "belowStimulus",
          "type": "reactive",
          "hidden": true
        }
      ],
      "nextButtonLocation": "sidebar",
      "instructionLocation": "aboveStimulus"
    },
